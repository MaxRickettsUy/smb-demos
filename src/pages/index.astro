---
import Layout from '../layouts/Layout.astro';

const demos = [
  {
    slug: 'tree-service',
    name: 'Ironwood Tree Co.',
    trade: 'Tree Service',
    location: 'Westminster, MD',
    href: 'demos/tree-service',
    status: 'Live',
  },
];
---
<Layout
  title="Small Business Demo Showroom"
  description="Minimal small-business website demos focused on contact details, services, and fast customer action."
>
  <main class="min-h-screen bg-paper text-ink">
    <header class="border-b border-line bg-white">
      <div class="mx-auto max-w-6xl px-5 py-8 md:px-8">
        <p class="label text-muted">The Showroom</p>
        <h1 class="mt-3 text-4xl font-semibold text-ink md:text-5xl">Small Business Demos</h1>
        <p class="mt-4 max-w-2xl leading-7 text-muted">
          Simple demonstration sites for local businesses. Each page prioritizes contact details,
          services, hours, and a clear way to get in touch.
        </p>
      </div>
    </header>

    <section class="mx-auto max-w-6xl px-5 py-10 md:px-8 md:py-14">
      <div class="mb-5 flex items-end justify-between gap-4 border-b border-line pb-3">
        <h2 class="text-lg font-semibold text-ink">Catalog</h2>
        <span class="text-sm text-muted">{demos.length} demos</span>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {demos.map((demo) => (
          <article class="rounded-lg border border-line bg-white p-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="label text-muted">{demo.trade}</p>
                <h3 class="mt-2 text-2xl font-semibold text-ink">{demo.name}</h3>
                <p class="mt-2 text-muted">{demo.location}</p>
              </div>
              <span class="rounded-full border border-line px-2.5 py-1 text-xs font-medium text-muted">{demo.status}</span>
            </div>
            <a
              href={`${import.meta.env.BASE_URL}/${demo.href}`.replace(/\/+/g, '/')}
              class="mt-6 inline-flex rounded-md bg-accent px-4 py-2 text-sm font-semibold text-white hover:opacity-90"
            >
              View
            </a>
          </article>
        ))}
      </div>

      <p class="mt-8 text-sm text-muted">More trades can be added by creating a data-driven demo page and adding it to this catalog.</p>
    </section>

    <footer class="border-t border-line bg-white">
      <div class="mx-auto max-w-6xl px-5 py-6 text-sm text-muted md:px-8">
        Built with Astro and Tailwind.
      </div>
    </footer>
  </main>
</Layout>
