---
import ContactCard from '../../../components/ContactCard.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Services from '../../../components/Services.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import Layout from '../../../layouts/Layout.astro';
import type { Business } from '../../../lib/business';

const business: Business = {
  name: 'Ironwood Tree Co.',
  trade: 'Tree Service',
  tagline: 'Tree removal, pruning, stump grinding, and storm response for Westminster homes and small properties.',
  location: 'Westminster, MD',
  phone: '(828) 555-0142',
  phoneHref: 'tel:+18285550142',
  email: 'hello@ironwoodtree.example',
  facebook: 'https://www.facebook.com/ironwoodtreeco',
  address: ['1849 Riverside Drive', 'Westminster, MD 21158'],
  hours: [
    { days: 'Mon-Fri', time: '7:00 AM-6:00 PM' },
    { days: 'Saturday', time: '8:00 AM-2:00 PM' },
    { days: 'Storm line', time: '24/7' },
  ],
  services: [
    { title: 'Tree Removal', blurb: 'Hazardous, diseased, and crowded trees removed with careful rigging and full cleanup.' },
    { title: 'Trimming & Pruning', blurb: 'Structural pruning, crown thinning, deadwood removal, and seasonal maintenance.' },
    { title: 'Stump Grinding', blurb: 'Stumps ground below grade, with mulch hauled off or left on-site by request.' },
    { title: 'Emergency Storm Response', blurb: 'Fast help for downed limbs, blocked drives, and trees on structures.' },
  ],
  license: 'MD Tree Expert License #2918',
  founded: '1987',
  heroImage: 'https://images.unsplash.com/photo-1448375240586-882707db888b?w=1200&q=80&auto=format',
  accent: '#2f6f4e',
};
---
<Layout
  title={`${business.name} · ${business.trade} · ${business.location}`}
  description={`${business.name} provides ${business.trade.toLowerCase()} in ${business.location}. Call ${business.phone} or email ${business.email}.`}
>
  <main id="top" class="min-h-screen bg-paper text-ink" style={`--accent: ${business.accent};`}>
    <SiteHeader business={business} />

    <section class="mx-auto grid max-w-6xl gap-8 px-5 py-12 md:grid-cols-[1fr_360px] md:px-8 md:py-16">
      <div class="self-center">
        <p class="label text-muted">{business.location}</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-normal text-ink md:text-6xl">{business.name}</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-muted md:text-xl">{business.tagline}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={business.phoneHref} class="rounded-md bg-[var(--accent)] px-5 py-3 text-center text-sm font-semibold text-white hover:opacity-90">
            Call {business.phone}
          </a>
          <a href={`mailto:${business.email}`} class="rounded-md border border-line bg-white px-5 py-3 text-center text-sm font-semibold text-ink hover:border-[var(--accent)]">
            Email us
          </a>
        </div>
      </div>

      {business.heroImage && (
        <img
          src={business.heroImage}
          alt="Forest canopy"
          class="h-72 w-full rounded-lg object-cover md:h-full"
        />
      )}
    </section>

    <Services services={business.services} />

    <section id="contact" class="border-t border-line py-14 md:py-18">
      <div class="mx-auto grid max-w-6xl gap-6 px-5 md:grid-cols-2 md:px-8">
        <ContactCard business={business} />
        <ContactForm />
      </div>
    </section>

    <SiteFooter business={business} />
  </main>
</Layout>
