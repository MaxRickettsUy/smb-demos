---
import type { Business } from '../lib/business';

interface Props {
  business: Business;
}

const { business } = Astro.props;
const showroomHref = import.meta.env.BASE_URL || '/';
---
<footer class="border-t border-line bg-white">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-8 text-sm text-muted md:flex-row md:items-center md:justify-between md:px-8">
    <div>
      <div class="font-semibold text-ink">{business.name}</div>
      <div class="mt-1">
        <a href={business.phoneHref} class="hover:text-[var(--accent)]">{business.phone}</a>
        <span aria-hidden="true"> / </span>
        <a href={`mailto:${business.email}`} class="hover:text-[var(--accent)]">{business.email}</a>
        {business.facebook && (
          <>
            <span aria-hidden="true"> / </span>
            <a href={business.facebook} class="hover:text-[var(--accent)]">Facebook</a>
          </>
        )}
      </div>
      {(business.license || business.founded) && (
        <div class="mt-1">
          {business.license && <span>{business.license}</span>}
          {business.license && business.founded && <span aria-hidden="true"> / </span>}
          {business.founded && <span>Founded {business.founded}</span>}
        </div>
      )}
    </div>
    <a href={showroomHref} class="font-medium text-ink hover:text-[var(--accent)]">Back to Showroom</a>
  </div>
</footer>
