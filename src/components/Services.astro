---
import type { Business } from '../lib/business';

interface Props {
  services: Business['services'];
}

const { services } = Astro.props;
---
<section id="services" class="border-t border-line py-14 md:py-18">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="max-w-2xl">
      <p class="label text-muted">Services</p>
      <h2 class="mt-3 text-3xl font-semibold text-ink md:text-4xl">What we do</h2>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {services.map((service) => (
        <article class="rounded-lg border border-line bg-white p-5">
          <h3 class="text-lg font-semibold text-ink">{service.title}</h3>
          {service.blurb && <p class="mt-2 leading-6 text-muted">{service.blurb}</p>}
        </article>
      ))}
    </div>
  </div>
</section>
